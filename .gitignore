ragfiles/
# cache do thesaurus / expansions
cache/
# ~150MB de dicionários gerados (regerar com tools/build_thesaurus.py); licença de dados própria
thesaurus/
# drivers gerados (fonte de verdade = tools/gen_drivers.py + seeds em drivers/)
drivers.out/

# ── Corpora de exemplo COM COPYRIGHT (não redistribuir) ──
# narnia / percy / sda — textos protegidos, usados só como teste local
importables/
# texto e excerto do Senhor dos Anéis usados na trilha (substituir por domínio público)
logic_path/sda.txt
logic_path/sample.txt

# ── Notas de trabalho internas (IP de LAN, OpenFrame/NAT, estratégia) ──
# tirar do repo público; recriar uma pasta docs/ curada depois se quiser
docs/

# ── Textos de divulgação (prazo de validade — trocam a cada release) ──
# posts de LinkedIn/Face/Insta por versão; não poluir o histórico do repo OSS
announce/

# ── To-do interno (vira GitHub Issues; não duplicar no repo) ──
to-do-list.md

# ── VEGA2 (projeto separado; estudo+diversão, não faz parte do core OSS) ──
# notas de integração e qualquer artefato de cruzamento RAGnaRock × cluster ESP32
VEGA2_*
vega2/

# ── Build artifacts ──
**/target/
**/node_modules/

# ── Logs / temporários / OS ──
*.log
*.tmp
